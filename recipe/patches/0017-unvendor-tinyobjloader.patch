From d2e0ab1f99dc4806c5be27e129803b9b7ef4217a Mon Sep 17 00:00:00 2001
From: Silvio Traversaro <silvio@traversaro.it>
Date: Mon, 16 Mar 2026 12:22:37 +0100
Subject: [PATCH] Devendor tinyobjloader

---
 cmake/MujocoDependencies.cmake    | 2 +-
 plugin/obj_decoder/CMakeLists.txt | 2 --
 2 files changed, 1 insertion(+), 3 deletions(-)

diff --git a/cmake/MujocoDependencies.cmake b/cmake/MujocoDependencies.cmake
index d2404bc186..0166f0443f 100644
--- a/cmake/MujocoDependencies.cmake
+++ b/cmake/MujocoDependencies.cmake
@@ -178,7 +178,7 @@ if(NOT DEFINED CMAKE_POLICY_VERSION_MINIMUM)
 endif()
 findorfetch(
   USE_SYSTEM_PACKAGE
-  OFF
+  ON
   PACKAGE_NAME
   tinyobjloader
   LIBRARY_NAME
diff --git a/plugin/obj_decoder/CMakeLists.txt b/plugin/obj_decoder/CMakeLists.txt
index 17b671997c..fb2bf6912f 100644
--- a/plugin/obj_decoder/CMakeLists.txt
+++ b/plugin/obj_decoder/CMakeLists.txt
@@ -37,8 +37,6 @@ else()
   )
 endif()
 
-target_compile_definitions(obj_decoder PRIVATE TINYOBJLOADER_IMPLEMENTATION)
-
 target_compile_options(obj_decoder PRIVATE
   ${AVX_COMPILE_OPTIONS}
   ${MUJOCO_MACOS_COMPILE_OPTIONS}
